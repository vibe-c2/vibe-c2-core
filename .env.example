# App
APP_STAGE_STATUS=development
APP_DEBUG=false
# JWT
JWT_SECRET_KEY=changeme_jwt_secret

# MongoDB
MONGO_INITDB_ROOT_USERNAME=vibec2
MONGO_INITDB_ROOT_PASSWORD=changeme_mongo
MONGO_INITDB_DATABASE=vibec2
MONGO_URI=mongodb://vibec2:changeme_mongo@localhost:27018
MONGO_DATABASE=vibec2

# RabbitMQ
RABBITMQ_DEFAULT_USER=vibec2
RABBITMQ_DEFAULT_PASS=changeme_rabbitmq
RABBITMQ_ERLANG_COOKIE=vibec2_erlang_cookie
APP_RABBITMQ_HOST=localhost
APP_RABBITMQ_PORT=5672

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_ENABLED=true

# SeaweedFS
SEAWEEDFS_S3_ACCESS_KEY=vibec2
SEAWEEDFS_S3_SECRET_KEY=changeme_seaweedfs
SEAWEEDFS_S3_ENDPOINT=http://localhost:8333

# Hocuspocus (collab editing sidecar)
HOCUSPOCUS_TICKET_SECRET=changeme_hocuspocus_ticket
HOCUSPOCUS_WEBHOOK_SECRET=changeme_hocuspocus_webhook
HOCUSPOCUS_DEBOUNCE_MS=2000
WIKI_AUTO_BACKUP_INTERVAL=30m

# Wiki image uploads
WIKI_IMAGE_BUCKET=wiki-images
WIKI_IMAGE_MAX_SIZE=10485760
WIKI_IMAGE_MAX_DIMENSION=2560
WIKI_IMAGE_SWEEPER_INTERVAL=24h
WIKI_IMAGE_SWEEPER_GRACE=168h

# Wiki file attachments (non-image uploads)
WIKI_FILE_BUCKET=wiki-files
WIKI_FILE_MAX_SIZE=52428800
# Comma-separated MIME types to reject at upload time (empty = allow all).
WIKI_FILE_DENIED_CONTENT_TYPES=
WIKI_FILE_SWEEPER_INTERVAL=24h
WIKI_FILE_SWEEPER_GRACE=168h

# CORS — comma-separated list of allowed origins for the API.
# In production set this to your real frontend domain(s), e.g.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,https://localhost:8443
