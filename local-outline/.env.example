# Outline (reference wiki) — isolated local stack
# Run `make secrets` to generate the hex values, then fill in below.

OUTLINE_POSTGRES_PASSWORD=changeme_outline_pg

# 64-char hex; generate with: openssl rand -hex 32
OUTLINE_SECRET_KEY=
OUTLINE_UTILS_SECRET=

# Shared secret between Outline and Dex for the OIDC client.
OUTLINE_OIDC_CLIENT_SECRET=changeme_outline_oidc

# bcrypt hash of the admin@local password.
# Use `make hash PASSWORD=yourpassword` — it emits a ready-to-paste line,
# already single-quoted so compose doesn't interpret the `$` segments as
# variable references.
OUTLINE_DEX_ADMIN_HASH=''
